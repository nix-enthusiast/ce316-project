<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="800.0" spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iae.controller.ResultsGridController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2B2D30;" text=" Student Grading Results" />

    <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colStudentId" prefWidth="150" text="Student ID" />
            <TableColumn fx:id="colCompiled" prefWidth="130" text="Compilation Status" />
            <TableColumn fx:id="colExecuted" prefWidth="130" text="Execution Status" />
            <TableColumn fx:id="colMatch" prefWidth="150" text="Output Match" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#onBackToWorkspace" style="-fx-background-color: #6c757d; -fx-text-fill: white;" text="🡠 Back to Workspace" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onViewDetails" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text=" View Details &amp; Logs" />
    </HBox>

</VBox>