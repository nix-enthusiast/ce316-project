<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.iae.controller.ProjectWorkspaceController" prefWidth="800" prefHeight="500">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Project Workspace" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <Label fx:id="projectInfoLabel" style="-fx-font-size: 13; -fx-text-fill: #555;"/>
    <GridPane hgap="10" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
            <ColumnConstraints minWidth="80"/>
        </columnConstraints>

        <Label text="ZIP Directory:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="zipDirectoryField" promptText="Select the folder containing student ZIPs..." GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button text="Browse" onAction="#onBrowseZip" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

        <Label text="Expected Output:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="expectedOutputField" promptText="Select the expected output .txt file..." GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button text="Browse" onAction="#onBrowseExpectedOutput" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

        <Label text="Binary Args:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="binaryArgsField" promptText="e.g. arg1 arg2" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="2"/>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>

    <VBox spacing="5">
        <Label fx:id="statusLabel" text="Ready"/>
        <ProgressBar fx:id="progressBar" progress="0.0" maxWidth="Infinity"/>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="runPipelineBtn" text="▶️ RUN PIPELINE" onAction="#onRunPipeline"
                style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
    </HBox>
</VBox>