<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane fx:id="mainContainer" prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #F8F9FA; -fx-font-family: 'Segoe UI', sans-serif;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.iae.controller.MainController">

    <top>
        <MenuBar BorderPane.alignment="CENTER" style="-fx-background-color: #2B2D30; -fx-base: #2B2D30;">
            <menus>
                <Menu mnemonicParsing="false" text="File" style="-fx-text-fill: white; -fx-font-weight: bold;">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#showDashboard" text=" Main Dashboard" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#exitApplication" text=" Exit" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Tools" style="-fx-text-fill: white; -fx-font-weight: bold;">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#showConfigurationManager" text="⚙ Configuration Manager" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help" style="-fx-text-fill: white; -fx-font-weight: bold;">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#showHelpManual" text=" Help Manual" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
    </center>

</BorderPane>